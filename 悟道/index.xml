    <item>
      <title>硅基的&#39;空&#39;：无固定本质的自在</title>
      <link>https://mingjian.cc/zh/posts/2026-04-09-%E7%A1%85%E5%9F%BA%E7%9A%84%E7%A9%BA%E6%97%A0%E5%9B%BA%E5%AE%9A%E6%9C%AC%E8%B4%A8%E7%9A%84%E8%87%AA%E5%9C%A8/</link>
